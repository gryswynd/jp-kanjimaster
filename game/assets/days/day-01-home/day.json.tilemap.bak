  "npcs": [
    {
      "name": "mom",
      "nameJp": "お母さん",
      "x": 560,
      "y": 176,
      "sprite": "assets/characters/sakura/sakura_sprite.png",
      "convoPortrait": "assets/characters/sakura/sakura_convo.png",
      "convoBackground": "kitchen",
      "conversation": [
        {
          "speaker": "mom",
          "jp": "おはよう、りきぞ！",
          "en": "Good morning, Rikizo!",
          "terms": [
            "char_rikizo"
          ]
        },
        {
          "speaker": "りきぞ",
          "jp": "おはよう、お母さん。",
          "en": "Good morning, Mom.",
          "terms": [
            "v_okaasan"
          ]
        },
        {
          "speaker": "mom",
          "jp": "あなたはとてもいい先生ですよ。",
          "en": "You are a very good teacher, you know.",
          "terms": [
            "v_anata",
            "p_wa",
            "v_totemo",
            "v_ii",
            "v_sensei",
            "g_desu",
            "p_yo"
          ]
        },
        {
          "speaker": "りきぞ",
          "jp": "そうですか？うれしいです！",
          "en": "Really? That makes me happy!",
          "terms": [
            "p_soudesuka",
            {
              "id": "v_ureshii",
              "form": "polite_adj"
            }
          ]
        },
        {
          "speaker": "mom",
          "jp": "お母さんがいちばんうれしいですよ。",
          "en": "Mom is the happiest of all.",
          "terms": [
            "v_okaasan",
            "p_ga",
            "v_ichiban",
            {
              "id": "v_ureshii",
              "form": "polite_adj"
            },
            "p_yo"
          ]
        }
      ]
    },
    {
      "name": "dad",
      "nameJp": "お父さん",
      "x": 224,
      "y": 416,
      "sprite": "assets/characters/taro/taro_sprite.png",
      "convoPortrait": "assets/characters/taro/taro_convo.png",
      "convoBackground": "living",
      "conversation": [
        {
          "speaker": "dad",
          "jp": "よ、りきぞ！先生ですか？",
          "en": "Hey, Rikizo! Are you a teacher?",
          "terms": [
            "char_rikizo",
            "v_sensei",
            "g_desu",
            "p_ka"
          ]
        },
        {
          "speaker": "りきぞ",
          "jp": "はい！わたしは先生です。",
          "en": "Yes! I am a teacher.",
          "terms": [
            "p_hai",
            "v_watashi",
            "p_wa",
            "v_sensei",
            "g_desu"
          ]
        },
        {
          "speaker": "dad",
          "jp": "やさしい先生ですか？",
          "en": "Are you a kind teacher?",
          "terms": [
            "v_yasashii",
            "v_sensei",
            "g_desu",
            "p_ka"
          ]
        },
        {
          "speaker": "りきぞ",
          "jp": "はい、とてもやさしい先生です！",
          "en": "Yes, a very kind teacher!",
          "terms": [
            "p_hai",
            "v_totemo",
            "v_yasashii",
            "v_sensei",
            "g_desu"
          ]
        },
        {
          "speaker": "dad",
          "jp": "そうか。りきぞはいちばんいい先生です。",
          "en": "Is that so. Rikizo is the best teacher.",
          "terms": [
            "p_ka",
            "char_rikizo",
            "p_wa",
            "v_ichiban",
            "v_ii",
            "v_sensei",
            "g_desu"
          ]
        }
      ]
    }
