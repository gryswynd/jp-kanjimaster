# Godot editor import cache — regenerated on first open / --headless --import.
.godot/

# Exported build output (iOS Xcode project, 100MB+ libgodot binaries) — regenerate
# via the Godot export command. Too big for GitHub; never commit.
build/

# NOTE: unlike the jp-lessons original, this kanjimaster COPY commits assets/,
# export_presets.cfg, and *.import — they are the game, and a fresh clone needs
# them to open + export. (jp-lessons regenerated assets via setup_assets.sh.)
