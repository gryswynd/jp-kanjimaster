# Controls what `gcloud run deploy --source .` uploads to Cloud Build.
# CRITICAL: without this file, gcloud falls back to .gitignore — which excludes
# curriculum/ — and the lookup_curriculum tool would silently break in the image.
# This file mirrors .dockerignore but KEEPS curriculum/ (staged by predeploy).
.git
.gitignore
node_modules
.env
*.local
service-account*.json
.build.log
.sync.log
smoke*.mjs
smoke*.sh
deploy.sh
add-secrets.sh
run-local.sh
# curriculum/ intentionally NOT ignored — it must ship in the image.
