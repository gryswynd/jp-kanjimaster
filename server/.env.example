# Rikizo tutor server — copy to .env (gitignored) and fill in.
# In Cloud Run these come from Secret Manager + service config, not a file.

# --- Anthropic (Claude) ---
ANTHROPIC_API_KEY=
# Haiku is the V1 Press-to-Ask model (cheap). Override to test other tiers.
ANTHROPIC_MODEL=claude-haiku-4-5-20251001

# --- Google Speech-to-Text (voice questions) ---
# Simple API-key auth via the STT REST endpoint. Create the key in Google Cloud
# Console → APIs & Services → Credentials → Create credentials → API key, with
# the Cloud Speech-to-Text API enabled for the project. Restrict it to the
# Speech-to-Text API. Leave blank to disable voice (typed questions still work).
STT_API_KEY=

# STT uses the v2 API + Chirp 2 model (handles English+Japanese mixed in one
# sentence). v2 REQUIRES your Google Cloud project id here, and the Cloud
# Speech-to-Text API (v2) must be enabled for that project. Find the id in the
# Cloud Console top bar (e.g. "rikizo-tutor-123456"). Voice fails without it.
GCLOUD_PROJECT=

# Optional STT tuning. Chirp 2 needs a regional endpoint (not global); us-central1
# is a safe default. Override only if you know you want a different region/model.
# STT_LOCATION=us-central1
# STT_MODEL=chirp_2

# --- iOS App Attest ---
# Apple team id + the app's bundle id, used to build the expected appId hash.
APPLE_TEAM_ID=
APP_BUNDLE_ID=com.rikizo.app
# Dev escape hatch: when true, skip attestation (NEVER set in production).
ATTEST_BYPASS=true

# --- Server ---
PORT=8080
# Comma-separated device ids granted a tier above "free" for the family beta.
# Format: deviceId:tier  e.g. "abc-123:premium,def-456:premium"
BETA_ENTITLEMENTS=

# --- Admin cost dashboard (GET /v1/admin/dashboard) ---
# Gate is OR: a request passes if its Firebase uid is in ADMIN_UIDS, OR it presents
# ADMIN_TOKEN (via X-Admin-Token header or ?token= query). Set at least one in
# production. With NEITHER set, the dashboard is OPEN only in local memory-store
# mode (and logs a warning); production fails closed.
# Comma-separated Firebase uids allowed to view costs.
ADMIN_UIDS=
# Shared secret for opening the dashboard URL directly in a browser
# (https://<host>/v1/admin/dashboard?token=<this>). Use a long random string.
ADMIN_TOKEN=
