.DS_Store
**/.DS_Store

# Node / Capacitor
node_modules/
# Build output (regenerate with: npm run build:www)
www/
# Native iOS project (generated on the Mac via: npx cap add ios)
/ios/

# Firebase Hosting local deploy cache
.firebase/

# Godot game — regenerable build output + editor cache (NOT source).
# build/ holds the exported iOS Xcode project incl. 100MB+ libgodot binaries that
# exceed GitHub's hard file-size limit; regenerate via the Godot export command.
game/build/
# .godot/ is the editor's import cache; regenerated on first open / --headless --import.
game/.godot/
